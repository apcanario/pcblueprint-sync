# pcblueprint-api base URL (internal Docker network)
API_URL=http://pcblueprint-api:3001
# Bearer token for the sync worker (distinct from website token)
API_TOKEN=

# Zepp / Amazfit credentials
ZEPP_EMAIL=
ZEPP_PASSWORD=
ZEPP_REGION=eu

# Strava OAuth credentials
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Optional: webhook URL for job-failure alerts (e.g. Discord, Slack)
ALERT_WEBHOOK_URL=
